# =====================================================
# CONFIGURACIÓN DEL BACKEND - WhatsApp Clone
# =====================================================
# 
# 📋 INSTRUCCIONES:
# 1. Copia este archivo y renómbralo a ".env"
# 2. Modifica los valores según tu configuración
# 3. IMPORTANTE: La contraseña de MySQL debe ser la tuya
#
# =====================================================

# ----- SERVIDOR -----
PORT=3001
NODE_ENV=development

# ----- BASE DE DATOS MYSQL -----
# ⚠️ IMPORTANTE: Cambia DB_PASSWORD por tu contraseña de MySQL
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=TU_CONTRASEÑA_DE_MYSQL_AQUI
DB_NAME=whatsapp_db

# ----- JWT (Autenticación) -----
# Genera una clave secreta única para producción
JWT_SECRET=mi_super_secreto_jwt_cambiar_en_produccion_12345
JWT_EXPIRES_IN=7d

# ----- CORS -----
# En desarrollo puedes usar *, en producción especifica el dominio
CORS_ORIGIN=*

# ----- SUBIDA DE ARCHIVOS -----
MAX_FILE_SIZE=10485760
UPLOAD_PATH=./uploads

# ----- ENCRIPTACIÓN DE MENSAJES -----
# Genera una clave única de 64 caracteres hexadecimales
# Puedes usar: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
ENCRYPTION_KEY=f14388868d120115fe20470978be07a6991a61d21c4986a04bbc09d2b64a91d8

# ----- DAILY.CO (Videollamadas) -----
# Obtén tu API Key en: https://dashboard.daily.co/developers
DAILY_API_KEY=tu_api_key_de_daily_aqui
DAILY_DOMAIN=tu_dominio.daily.co

# ----- URL DEL FRONTEND -----
FRONTEND_URL=http://localhost:5173
